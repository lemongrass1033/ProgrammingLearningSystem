    private void btnSearchActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnSearchActionPerformed

    UserDAO dao =
            new UserDAO();

    User user =
            dao.getAnyUserByUsername(
                    txtUsername.getText().trim());

    if(user != null){

        lblCurrentRole.setText(
                user.getRole());

    }else{

        JOptionPane.showMessageDialog(
                this,
                "User not found");
    }
        
    }//GEN-LAST:event_btnSearchActionPerformed

    private void btnBackActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnBackActionPerformed
  
    AdminFrame admin =
            new AdminFrame();

    admin.setVisible(true);

    this.dispose();
    }//GEN-LAST:event_btnBackActionPerformed

    private void btnUpdateRoleActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnUpdateRoleActionPerformed
        UserDAO dao =
            new UserDAO();

    boolean success =
            dao.updateRole(
                    txtUsername.getText(),
                    cmbRole.getSelectedItem().toString());

    if(success){

        JOptionPane.showMessageDialog(
                this,
                "Role Updated Successfully");

        lblCurrentRole.setText(
                cmbRole.getSelectedItem().toString());

    }else{

        JOptionPane.showMessageDialog(
                this,
                "Update Failed");
    }
    }//GEN-LAST:event_btnUpdateRoleActionPerformed

