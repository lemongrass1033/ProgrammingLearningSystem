    public StudentMaterialFrame(
        int topicID,
           int courseID) {

    initComponents();
    
    this.currentTopicID = topicID;
      this.currentCourseID = courseID;

    MaterialController controller =
            new MaterialController();

    textMaterials.setText(
            controller.viewMaterialByTopic(
                    topicID));
}
    
