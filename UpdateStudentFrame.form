    public StudentTopicFrame() {
        initComponents();
    }
    
    public StudentTopicFrame(
        int courseID) {

    initComponents();
    

    this.currentCourseID = courseID;
    
    topicList.setModel(
            topicModel);

    TopicController controller =
            new TopicController();

    String result =
            controller.searchTopicByCourseID(
                    courseID);

    String[] lines =
            result.split("\n");

    for(String line : lines) {

        if(!line.trim().isEmpty()) {

            topicModel.addElement(
                    line);
        }
    }
}
    
