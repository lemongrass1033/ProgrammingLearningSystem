    public LearningProgressFrame() {
        initComponents();
        jProgressTable.getColumnModel().getColumn(0).setPreferredWidth(0);
        
        DefaultTableCellRenderer centerRenderer =new DefaultTableCellRenderer();

centerRenderer.setHorizontalAlignment(
        JLabel.CENTER);

for(int i = 0;
    i < jProgressTable.getColumnCount();
    i++) {

    jProgressTable.getColumnModel()
            .getColumn(i)
            .setCellRenderer(
                    centerRenderer);
}
((DefaultTableCellRenderer) jProgressTable.getTableHeader() .getDefaultRenderer()) .setHorizontalAlignment( JLabel.CENTER); 
jProgressTable.setRowHeight(25);
    }
    
    public LearningProgressFrame(String role) {
    initComponents();


}

