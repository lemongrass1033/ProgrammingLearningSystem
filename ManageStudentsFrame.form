    private void btnViewProgressActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnViewProgressActionPerformed
    try {

    DatabaseManager db = new DatabaseManager();

    ResultSet rs = db.viewProgress();

    DefaultTableModel model = (DefaultTableModel)
            jProgressTable.getModel();

    model.setRowCount(0);
    
    int no =1;

    while(rs.next()) {
        model.addRow(new Object[]{
            no++,
            rs.getInt("progress_id"),
            rs.getInt("enrollment_id"),
            rs.getDouble("progress_percentage")
        });
    }

} catch(Exception e) {
    e.printStackTrace();
}
    }//GEN-LAST:event_btnViewProgressActionPerformed

