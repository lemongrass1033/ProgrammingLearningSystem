   public MaterialFrame(
        int topicID, int CourseID, User currentUser) {
       
       System.out.println(
        "MaterialFrame User = "
        + currentUser);

    initComponents();
    
      this.currentTopicID = topicID;
    this.currentCourseID = CourseID;
    this.currentUser =
            currentUser;

    currentTopicID = topicID;

    textTopicID.setText(
            String.valueOf(topicID));
    
     textResult.setText(
            materialcontroller
                    .viewMaterialByTopic(
                            topicID));
     
  

     
}

