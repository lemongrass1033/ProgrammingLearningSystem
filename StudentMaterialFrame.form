    private void btnBackActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnBackActionPerformed

         TopicFrame frame =
            new TopicFrame(
                    currentUser,
                    currentCourseID);

    frame.setVisible(true);

    dispose();
    }//GEN-LAST:event_btnBackActionPerformed

    private void btnUploadMaterialActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnUploadMaterialActionPerformed
          try {

    int materialId =
            Integer.parseInt(
                    textMaterialID.getText());

} catch(Exception e) {

    JOptionPane.showMessageDialog(
            this,
            "Invalid Material ID");
}
        if(textMaterialID.getText().isEmpty()
        || textFileName.getText().isEmpty()
        || textFileType.getText().isEmpty()) {

    JOptionPane.showMessageDialog(
            this,
            "Please fill all fields");

    return;
}

int materialID =
        Integer.parseInt(
                textMaterialID.getText());

String fileName =
        textFileName.getText();

String fileType =
        textFileType.getText();

Material m =
        new Material(
                materialID,
                fileName,
                fileType,
                currentTopicID);

materialcontroller.uploadMaterial(m);

materialcontroller.addMaterialToDatabase(m);

JOptionPane.showMessageDialog(
        this,
        "Material Uploaded Successfully");

textMaterialID.setText("");
textFileName.setText("");
textFileType.setText("");
    }//GEN-LAST:event_btnUploadMaterialActionPerformed

    private void btnDownloadMaterialActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnDownloadMaterialActionPerformed
    int materialId =
            Integer.parseInt(
                    textMaterialID.getText());

    Material m =
            materialcontroller.getMaterial(materialId);

    if(m != null) {

        m.downloadMaterial();

        JOptionPane.showMessageDialog(
                this,
                "Material Downloaded Successfully");

    } else {

        JOptionPane.showMessageDialog(
                this,
                "Material Not Found");
    }
    }//GEN-LAST:event_btnDownloadMaterialActionPerformed

    private void btnViewMaterialActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnViewMaterialActionPerformed
  try {

        int materialId =
                Integer.parseInt(
                        textMaterialID.getText());

        String material =
                materialcontroller
                .viewMaterialByID(materialId);

        JOptionPane.showMessageDialog(
                this,
                material);

    } catch(Exception e) {

        JOptionPane.showMessageDialog(
                this,
                "Please enter a valid Material ID");
    }       
    String materials =
            materialcontroller
            .viewMaterialsFromDatabase();

    JOptionPane.showMessageDialog(
            this,
            materials);
    }//GEN-LAST:event_btnViewMaterialActionPerformed

    private void btnUpdateMaterialActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnUpdateMaterialActionPerformed
        int materialId =
            Integer.parseInt(
                    textMaterialID.getText());

    String fileName =
            textFileName.getText();

    String fileType =
            textFileType.getText();

    Material m =
        new Material(
                materialId,
                fileName,
                fileType,
                currentTopicID);

    materialcontroller
            .updateMaterialInDatabase(m);

    JOptionPane.showMessageDialog(
            this,
            "Material Updated Successfully");
    }//GEN-LAST:event_btnUpdateMaterialActionPerformed

    private void btnDeleteMaterialActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnDeleteMaterialActionPerformed
        int materialId =
            Integer.parseInt(
                    textMaterialID.getText());

    int choice =
        JOptionPane.showConfirmDialog(
                this,
                "Delete this material?",
                "Confirm Delete",
                JOptionPane.YES_NO_OPTION);

if(choice ==
        JOptionPane.YES_OPTION) {

    materialcontroller
            .deleteMaterialFromDatabase(materialId);
}

    JOptionPane.showMessageDialog(
            this,
            "Material Deleted Successfully");

    textMaterialID.setText("");
    textFileName.setText("");
    textFileType.setText("");
    }//GEN-LAST:event_btnDeleteMaterialActionPerformed

    private void btnSearchActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnSearchActionPerformed
     
    String keyword =
            textSearch.getText();

    String result =
            materialcontroller
                    .searchMaterialByName(keyword);

    textResult.setText(result);
    }//GEN-LAST:event_btnSearchActionPerformed

