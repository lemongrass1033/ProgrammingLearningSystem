    public EnrollmentFrame() {
        initComponents();
        DefaultTableCellRenderer centerRenderer = new DefaultTableCellRenderer();

    centerRenderer.setHorizontalAlignment(JLabel.CENTER);

    for(int i = 0;
        i < jEnrollTable.getColumnCount(); i++) {

        jEnrollTable.getColumnModel().getColumn(i).setCellRenderer(centerRenderer);
    }

    ((DefaultTableCellRenderer)
    jEnrollTable.getTableHeader().getDefaultRenderer()).setHorizontalAlignment(JLabel.CENTER);

    jEnrollTable.setRowHeight(25);
    }
    
    public EnrollmentFrame(String role) {
    initComponents();

    if(role.equalsIgnoreCase("Visitor")) {
        jenrollmentStatus.setVisible(false);
        cbEnrollStatus.setVisible(false);
        btnEnroll.setVisible(false);
        btnDelete.setVisible(false);
    }
    }
   
