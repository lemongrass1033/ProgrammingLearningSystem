    private void btnAddTopicActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnAddTopicActionPerformed
          
    try {

        if(textTopicID.getText().trim().isEmpty()
                || textTopicName.getText().trim().isEmpty()
                || textCourseID.getText().trim().isEmpty()) {

            JOptionPane.showMessageDialog(
                    this,
                    "Please fill all fields");

            return;
        }

        int topicID =
                Integer.parseInt(
                        textTopicID.getText());

        String topicName =
                textTopicName.getText();

        int courseID =
                Integer.parseInt(
                        textCourseID.getText());

        // 检查 Topic ID 是否已存在
        if(controller.topicExists(topicID)) {

            JOptionPane.showMessageDialog(
                    this,
                    "Topic ID already exists");

            return;
        }

        Topic topic =
                new Topic(
                        topicID,
                        topicName,
                        courseID);

        controller.createTopic(topic);

        controller.addTopicToDatabase(topic);

        JOptionPane.showMessageDialog(
                this,
                "Topic Added Successfully");

        textTopicID.setText("");
        textTopicName.setText("");
        textCourseID.setText("");

    } catch(NumberFormatException e) {

        JOptionPane.showMessageDialog(
                this,
                "Topic ID and Course ID must be numbers");

    } catch(Exception e) {

        JOptionPane.showMessageDialog(
                this,
                "Error : " + e.getMessage());

        e.printStackTrace();
    }
    }//GEN-LAST:event_btnAddTopicActionPerformed

    private void btnViewTopicActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnViewTopicActionPerformed
         String topics =
            controller
            .viewTopicsFromDatabase();

    JOptionPane.showMessageDialog(
            this,
            topics);
    }//GEN-LAST:event_btnViewTopicActionPerformed

    private void btnUpdateTopicActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnUpdateTopicActionPerformed
         int topicID =
            Integer.parseInt(
                    textTopicID.getText());

    String topicName =
            textTopicName.getText();

    int courseID =
        Integer.parseInt(
                textCourseID.getText());

Topic topic =
        new Topic(
                topicID,
                topicName,
                courseID);

    controller
            .updateTopicInDatabase(topic);

    JOptionPane.showMessageDialog(
            this,
            "Topic Updated Successfully");
    }//GEN-LAST:event_btnUpdateTopicActionPerformed

    private void btnDeleteTopicActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnDeleteTopicActionPerformed
         int topicID =
            Integer.parseInt(
                    textTopicID.getText());

    controller
            .deleteTopicFromDatabase(
                    topicID);

    JOptionPane.showMessageDialog(
            this,
            "Topic Deleted Successfully");
    }//GEN-LAST:event_btnDeleteTopicActionPerformed

    private void btnBackActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnBackActionPerformed

    ManageCoursesFrame frame =
            new ManageCoursesFrame();

    frame.setVisible(true);

    dispose();
    }//GEN-LAST:event_btnBackActionPerformed

    private void btnManageMaterialActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnManageMaterialActionPerformed
 
        int topicID;

    if(!textTopicID.getText().isEmpty()) {

        topicID =
                Integer.parseInt(
                        textTopicID.getText());

    } else {

        String selected =
                topicList.getSelectedValue();

        if(selected == null) {

            JOptionPane.showMessageDialog(
                    this,
                    "Please Select a Topic");

            return;
        }

        topicID =
                Integer.parseInt(
                        selected
                                .split("-")[0]
                                .trim());
    }

    MaterialFrame frame =
            new MaterialFrame(
                    topicID,
                    currentCourseID,
                    currentUser);

    frame.setVisible(true);

    dispose();
    }//GEN-LAST:event_btnManageMaterialActionPerformed

    private void btnSearchTopicActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnSearchTopicActionPerformed
        int courseID =
        Integer.parseInt(
                textSearch.getText());

String result =
        controller.searchTopicByCourseID(
                courseID);

JOptionPane.showMessageDialog(
        this,
        result);

topicModel.clear();

String[] lines =
        result.split("\n");

    for(String line : lines) {

        if(!line.trim().isEmpty()) {

            topicModel.addElement(
                    line);
        }
    }
    System.out.println(
        "List Size = "
        + topicModel.size());
    
    topicList.setModel(topicModel);
    }//GEN-LAST:event_btnSearchTopicActionPerformed

    private void topicListMouseClicked(java.awt.event.MouseEvent evt) {//GEN-FIRST:event_topicListMouseClicked
        String selected =
            topicList.getSelectedValue();

    if(selected == null) {

        return;
    }

    String[] parts =
            selected.split("-");

    textTopicID.setText(
            parts[0].trim());

    textTopicName.setText(
            parts[1].trim());
    }//GEN-LAST:event_topicListMouseClicked

