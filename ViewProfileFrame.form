    public TopicFrame(
        User currentUser,
        int courseID) {

    initComponents();

    this.currentUser =
            currentUser;
    
    this.currentCourseID = courseID;

     textSearch.setText(
            String.valueOf(courseID));

    topicList.setModel(topicModel);

String result =
        controller
                .searchTopicByCourseID(
                        courseID);

String[] lines =
        result.split("\n");

for(String line : lines) {

    if(!line.trim().isEmpty()) {

        topicModel.addElement(line);
    }
}
}
    
