private void loadCourses(){

    CourseDAO dao =
            new CourseDAO();

    txtResult.setText(
            "Total Courses : "
            + dao.getCourses().size()
            + "\n\n");

    for(String course :
            dao.getCourses()){

        txtResult.append(
                course + "\n");
    }
}
