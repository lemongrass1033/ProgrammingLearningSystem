    }//GEN-LAST:event_txtNewCourseActionPerformed

    private void btnUpdateCourseActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnUpdateCourseActionPerformed
        if(txtCourse.getText().trim().isEmpty()
       || txtNewCourse.getText().trim().isEmpty()){

        javax.swing.JOptionPane.showMessageDialog(
                this,
                "Please fill both fields");

        return;
    }

    CourseDAO dao =
            new CourseDAO();

    dao.updateCourse(
            txtCourse.getText(),
            txtNewCourse.getText());

    txtResult.setText(
            "Total Courses : "
            + dao.getCourses().size()
            + "\n\n");

    for(String course :
            dao.getCourses()){

        txtResult.append(
                course + "\n");
    }

    txtCourse.setText("");
    txtNewCourse.setText("");

    javax.swing.JOptionPane.showMessageDialog(
            this,
            "Course Updated Successfully");
    }//GEN-LAST:event_btnUpdateCourseActionPerformed

