    private void btnBackActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnBackActionPerformed
    new AdminFrame().setVisible(true);

    this.dispose();
    }//GEN-LAST:event_btnBackActionPerformed

     private void sortAndRank() {

        DefaultTableModel model =(DefaultTableModel)tblReport.getModel();

        int rows =model.getRowCount();

        for(int i = 0; i < rows - 1; i++) {

            for(int j = i + 1; j < rows; j++) {

                double score1 =Double.parseDouble(model.getValueAt(i,4).toString());

                double score2 = Double.parseDouble(model.getValueAt(j,4).toString());

                if(score2 > score1) {
                    for(int col = 1; col <= 4; col++) {

                   Object temp = model.getValueAt(i, col);

                   model.setValueAt(model.getValueAt(j, col),i,col);

                  model.setValueAt(temp,j,col);
}
                }
            }
        }

        for(int i = 0; i < rows; i++) {
            model.setValueAt(i + 1, i, 0);
        }
    }

