    private void btnCalculateTOPSISActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnCalculateTOPSISActionPerformed
  double progressWeight = Double.parseDouble(txfProgressWeight.getText());

double completionWeight = Double.parseDouble(txfCompletionWeight.getText());

if(Math.abs(
        (progressWeight + completionWeight) - 100) > 0.01) {

    JOptionPane.showMessageDialog(this,"Total Weight Must Equal 100%");
    return;
}

TopsisCalculator topsis = new TopsisCalculator( progressWeight,completionWeight);

DefaultTableModel model =(DefaultTableModel)
        tblReport.getModel();

model.setRowCount(0);

DatabaseManager db =new DatabaseManager();

HashMap<Integer, Double> progressMap =new HashMap<>();

try {
    ResultSet progressRs =db.getLearningProgress();
    while(progressRs.next()) {

        progressMap.put(
            progressRs.getInt("enrollment_id"),

            progressRs.getDouble("progress_percentage")
        );
    }

    ResultSet completionRs =db.getCompletionStatus();
    while(completionRs.next()) {

        int enrollmentId =completionRs.getInt("enrollment_id");

        if(!progressMap.containsKey(enrollmentId)) {
            continue;
        }

        double progressPercentage = progressMap.get(enrollmentId);

        double completionPercentage = completionRs.getDouble( "completion_percentage");

      double score =
        topsis.calculateScore(
                progressPercentage,
                completionPercentage);

String email =
        db.getUserEmailByEnrollment(
                enrollmentId);

if(email.equals("")) {
    continue;
}

model.addRow(new Object[]{
    0,
    email,
    progressPercentage,
    completionPercentage,
    score
});
    }

} catch(Exception e) {
    e.printStackTrace();
}

sortAndRank();

jRankingREsult.setText(
        "Ranking Generated");
    }//GEN-LAST:event_btnCalculateTOPSISActionPerformed

