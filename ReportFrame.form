    private void btnSearchActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btnSearchActionPerformed
         UserDAO dao =
            new UserDAO();

    User user =
           dao.getAnyUserByUsername(
                    txtUsername.getText());

    if(user != null){

        txtResult.setText(

                "========== USER DETAILS ==========\n\n"

                + "Username : "
                + user.getUsername()

                + "\nEmail : "
                + user.getEmail()

                + "\nSkill : "
                + user.getSkill()

                + "\nRole : "
                + user.getRole()

                + "\nStatus : "
                + user.getStatus());

    } else {

        txtResult.setText(
                "User Not Found");
    }
    }//GEN-LAST:event_btnSearchActionPerformed

