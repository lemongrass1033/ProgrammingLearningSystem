private void loadProfile() {

    ProfileController controller =
            new ProfileController();

    User user =
            controller.getProfile(
                    com.mycompany.programminglearningsystem.session.Session.currentUserEmail);

    if(user != null){

      txtUsername.setText(
        user.getUsername());

txtEmail.setText(
        user.getEmail());

SkillDAO skillDAO =
        new SkillDAO();

ArrayList<Skill> skills =
        skillDAO.getSkillsByEmail(
                txtEmail.getText());

for(Skill skill : skills){

    if(skill.getSkillName().equals("Java")){

        chkJava.setSelected(true);
    }

    if(skill.getSkillName().equals("Database")){

        chkDatabase.setSelected(true);
    }

    if(skill.getSkillName().equals("Networking")){

        chkNetworking.setSelected(true);
    }

    if(skill.getSkillName().equals("Python")){

        chkPython.setSelected(true);
    
}
